#compdef swflutter

_swflutter_subcommands() {
	local -a commands
	commands=(
		'get:show current version'
		'list:show available versions'
		'set:switch to the specified version'
		'help:show usage'
	)
	_describe -t commands 'commands' commands "$@"
}

_swflutter_versions() {
	local versions
	versions=($(swflutter list))
	_describe -t versions 'version' versions "$@"
}

_swflutter() {
	_arguments -C \
		'1: :_swflutter_subcommands' \
		'*:: :->args'

	case "$state" in
	args)
		case ${words[1]} in
		set)
			_arguments -C \
				'1: :_swflutter_versions'
			;;
		esac
		;;
	esac
}

_swflutter "$@"
