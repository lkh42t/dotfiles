#compdef swtex

_swtex_subcommands() {
	local -a commands
	commands=(
		'get:show current version'
		'list:show available versions'
		'set:switch to the specified version'
		'help:show usage'
	)
	_describe -t commands 'commands' commands "$@"
}

_swtex_versions() {
	local versions
	versions=($(swtex list))
	_describe -t versions 'version' versions "$@"
}

_swtex() {

	_arguments -C \
		'1: :_swtex_subcommands' \
		'*:: :->args'

	case "$state" in
	args)
		case ${words[1]} in
		set)
			_arguments -C \
				'1: :_swtex_versions'
			;;
		esac
		;;
	esac
}

_swtex "$@"
